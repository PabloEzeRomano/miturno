generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Barber {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  slug         String        @unique
  shopName     String
  phone        String?
  isActive     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  services     Service[]
  appointments Appointment[]
  availability Availability[]
  blockedDates BlockedDate[]
}

model Service {
  id           String        @id @default(cuid())
  barberId     String
  barber       Barber        @relation(fields: [barberId], references: [id])
  name         String
  durationMins Int
  price        Float
  isActive     Boolean       @default(true)
  appointments Appointment[]
}

model Availability {
  id        String  @id @default(cuid())
  barberId  String
  barber    Barber  @relation(fields: [barberId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)

  @@unique([barberId, dayOfWeek])
}

model BlockedDate {
  id       String   @id @default(cuid())
  barberId String
  barber   Barber   @relation(fields: [barberId], references: [id])
  date     DateTime
  reason   String?
}

model Appointment {
  id           String   @id @default(cuid())
  barberId     String
  barber       Barber   @relation(fields: [barberId], references: [id])
  serviceId    String
  service      Service  @relation(fields: [serviceId], references: [id])
  clientName   String
  clientPhone  String
  clientEmail  String?
  startsAt     DateTime
  endsAt       DateTime
  status       String   @default("confirmed")
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())
}
